<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15.0" prefWidth="450.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.project.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <Label text="Days ahead:" />
                <TextField fx:id="daysField" text="7" prefWidth="60.0" />
            </children>
        </HBox>

        <Separator />

        <HBox spacing="20.0">
            <children>
                <RadioButton fx:id="rbLatLon" text="Lat/Lon" selected="true">
                    <toggleGroup>
                        <ToggleGroup fx:id="locationMode" />
                    </toggleGroup>
                </RadioButton>
                <RadioButton fx:id="rbName" text="Name" toggleGroup="$locationMode" />
            </children>
        </HBox>

        <GridPane hgap="10.0" vgap="10.0" style="-fx-border-color: red; -fx-padding: 10; -fx-border-width: 1;">
            <columnConstraints>
                <ColumnConstraints minWidth="100.0" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>
            <children>
                <Label text="Lat:" GridPane.rowIndex="0" />
                <TextField fx:id="latField" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Lon:" GridPane.rowIndex="1" />
                <TextField fx:id="lonField" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Location name:" GridPane.rowIndex="2" />
                <TextField fx:id="nameField" disable="true" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            </children>
        </GridPane>

        <VBox spacing="5.0">
            <children>
                <CheckBox fx:id="cbTemp" text="temp_2m" selected="true" />
                <CheckBox fx:id="cbPrecip" text="precipitation" />
                <CheckBox fx:id="cbPressure" text="surface_pressure" />
                <CheckBox fx:id="cbWind" text="wind_speed_10m" />
            </children>
        </VBox>

        <Button fx:id="fetchButton" maxWidth="Infinity" onAction="#handleFetch" text="fetch" />

        <TextArea fx:id="infoArea" editable="false" prefHeight="100.0" wrapText="true" />
    </children>
</VBox>